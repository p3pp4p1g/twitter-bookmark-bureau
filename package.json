{
  "name": "bookmark-bureau",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "cf:dev": "wrangler dev",
    "cf:deploy": "wrangler deploy",
    "cf:login": "wrangler login",
    "cf:whoami": "wrangler whoami",
    "cf:types": "wrangler types",
    "cf:provision": "tsx scripts/provision-cloudflare.ts",
    "db:migrate:local": "wrangler d1 migrations apply twitter-bookmarks --local",
    "db:migrate:remote": "wrangler d1 migrations apply twitter-bookmarks --remote",
    "import:file": "tsx src/cli/import-file.ts",
    "classify:pending": "tsx src/cli/classify-pending.ts",
    "consolidate:categories": "tsx src/cli/consolidate-categories.ts",
    "sync:twitter": "tsx src/cli/sync-twitter.ts",
    "agent:backfill": "tsx src/agent/backfill.ts",
    "agent:daily": "tsx src/agent/daily-sync.ts",
    "agent:history": "tsx src/agent/historical-backfill.ts",
    "agent:media": "tsx src/agent/reconcile-media-backlog.ts",
    "agent:classify:uncategorized": "tsx src/agent/classify-uncategorized.ts",
    "agent:cron:install": "bash scripts/install-wsl-cron.sh",
    "agent:cleanup:media": "bash scripts/cleanup-local-media.sh"
  },
  "dependencies": {
    "csv-parse": "^6.2.1",
    "dotenv": "^17.2.3",
    "hono": "^4.12.12",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "rettiwt-api": "^6.2.0",
    "x-client-transaction-id": "^0.1.9",
    "zod": "^4.1.11"
  },
  "overrides": {
    "picomatch": "^4.0.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260303.0",
    "@types/node": "^24.5.2",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.4",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vite": "^7.3.2",
    "vitest": "^3.2.4",
    "wrangler": "^4.80.0"
  }
}
