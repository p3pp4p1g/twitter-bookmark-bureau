APP_TITLE="Bookmark Bureau"
DEFAULT_IMPORT_SOURCE="manual"
GEMINI_MODEL="gemini-2.5-flash-lite"

# Optional server-side access gate for the whole app.
SITE_PSK=""
SESSION_SECRET=""

# Required for local CLI -> cloud import.
